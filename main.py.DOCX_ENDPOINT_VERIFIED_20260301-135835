    return {
        "ok": True,
        "type": "docx_analysis",
        "threadId": threadId or "",
        "filename": file.filename,
        "chars": len(text),
        "preview": text[:1500],
    }

def normalize_charjibit_event(payload: Dict[str, Any]) -> Dict[str, Any]:
    if not isinstance(payload, dict):
        raise HTTPException(status_code=400, detail="Invalid payload: object expected")

    if "event_id" in payload:
        tx = payload.get("transaction", {})
        return {
            "event_id": str(payload.get("event_id")),
            "event_type": str(payload.get("event_type", "transaction")),
            "transaction": tx if isinstance(tx, dict) else {},
            "description": payload.get("description") or "",
            "received_at": datetime.now(timezone.utc).isoformat(),
        }

    if "id" in payload and "amount" in payload:
        return {
            "event_id": str(payload.get("id")),
            "event_type": "transaction",
            "transaction": payload,
            "description": str(payload.get("description", "")) if payload.get("description") is not None else "",
            "received_at": datetime.now(timezone.utc).isoformat(),
        }

    raise HTTPException(
        status_code=400,
        detail="Unsupported Charjibit payload: expected event_id or transaction id/amount"
    )


def build_charjibit_status(
    external_id: str,
    bridge_status: str,
    message: str,
    issue_id: Optional[str] = None,
    can_post: Optional[bool] = None,
    details: Optional[Dict[str, Any]] = None,
) -> Dict[str, Any]:
    return {
        "external_id": external_id,
        "bridge_status": bridge_status,
        "message": message,
        "issue_id": issue_id,
        "can_post": can_post,
        "details": details or {},
    }


