from fastapi import FastAPI
from pydantic import BaseModel
from typing import Any, Dict, List, Optional
import os, json, time, uuid

app = FastAPI(title="AI Bridge API", version="0.3.4")

# Cloud Run: writable path
BRIDGE_LOG_PATH = os.getenv("BRIDGE_LOG_PATH", "/tmp/bridge_logs.jsonl")

# Small debug log
LOGS: List[Dict[str, Any]] = []
LOGS_MAX = 200

def _log(event: str, trace_id: str, lang: str = "en", meta: Optional[Dict[str, Any]] = None) -> None:
    rec = {"ts": time.time(), "event": event, "trace_id": trace_id, "lang": lang, "meta": meta or {}}
    LOGS.append(rec)
    if len(LOGS) > LOGS_MAX:
        del LOGS[: len(LOGS) - LOGS_MAX]

def _append_jsonl(path: str, obj: Dict[str, Any]) -> None:
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "a", encoding="utf-8") as f:
        f.write(json.dumps(obj, ensure_ascii=False) + "\n")

def _safe_read_jsonl_tail(path: str, limit: int) -> List[Dict[str, Any]]:
    if not os.path.exists(path):
        return []
    try:
        with open(path, "r", encoding="utf-8") as f:
            lines = f.readlines()[-limit:]
        out = []
        for ln in lines:
            ln = ln.strip()
            if not ln:
                continue
            try:
                out.append(json.loads(ln))
            except Exception:
                continue
        return out
    except Exception:
        return []

def _load_recent_examples(task_type: str, limit: int = 5) -> List[Dict[str, Any]]:
    items: List[Dict[str, Any]] = []
    try:
        if os.path.exists(BRIDGE_LOG_PATH):
            with open(BRIDGE_LOG_PATH, "r", encoding="utf-8") as f:
                for line in f:
                    line = line.strip()
                    if not line:
                        continue
                    rec = json.loads(line)
                    if rec.get("event") == "learn" and rec.get("task_type") == task_type:
                        items.append(rec)
    except Exception:
        return []
    return items[-limit:]

class TaskBody(BaseModel):
    task_type: str = "email_invoice"
    provider: str = "openai"
    text: str = ""
    data: Dict[str, Any] = {}
    dry_run: bool = True

class LearnBody(BaseModel):
    task_type: str = "email_invoice"
    provider: str = "manus"
    ok: bool = True
    input: Dict[str, Any] = {}
    output: Dict[str, Any] = {}
    notes: str = ""

class ValidateBody(BaseModel):
    task_type: str = "email_invoice"
    extracted: Dict[str, Any] = {}
    rules: Dict[str, Any] = {}
    ok: bool = True

@app.get("/")
def root():
    return {"ok": True, "service": "AI Bridge API"}

@app.get("/health")
def health():
    return {"ok": True}

@app.get("/debug/log")
def debug_log(limit: int = 50):
    limit = max(1, min(200, int(limit)))
    return {"ok": True, "count": len(LOGS[-limit:]), "items": LOGS[-limit:]}

@app.post("/bridge/task")
def bridge_task(body: TaskBody) -> Dict[str, Any]:
    trace_id = str(uuid.uuid4())
    _log("task.in", trace_id, "en", meta={"task_type": body.task_type, "provider": body.provider, "dry_run": body.dry_run})
    result = {
        "ok": True,
        "trace_id": trace_id,
        "task_type": body.task_type,
        "provider": body.provider,
        "summary": "task received",
        "extracted": body.data or {},
        "actions": [],
        "confidence": 0.5,
        "dry_run": body.dry_run,
    }
    _log("task.out", trace_id, "en", meta={"task_type": body.task_type})
    return result

@app.post("/bridge/classify")
def bridge_classify(body: TaskBody) -> Dict[str, Any]:
    trace_id = str(uuid.uuid4())
    _log("classify.in", trace_id, "en", meta={"task_type": body.task_type, "provider": body.provider})
    result = {
        "ok": True,
        "trace_id": trace_id,
        "task_type": body.task_type,
        "provider": body.provider,
        "summary": "classify received",
        "extracted": body.data or {},
        "confidence": 0.5,
    }
    _log("classify.out", trace_id, "en", meta={"task_type": body.task_type})
    return result

@app.post("/bridge/validate")
def bridge_validate(body: ValidateBody) -> Dict[str, Any]:
    trace_id = str(uuid.uuid4())
    _log("validate.in", trace_id, "en", meta={"task_type": body.task_type})
    return {
        "ok": True,
        "trace_id": trace_id,
        "task_type": body.task_type,
        "validated": bool(body.ok),
        "extracted": body.extracted,
        "rules": body.rules,
    }

@app.post("/bridge/learn")
def bridge_learn(body: LearnBody) -> Dict[str, Any]:
    trace_id = str(uuid.uuid4())
    _log("learn.in", trace_id, "en", meta={"task_type": body.task_type, "provider": body.provider})
    rec = {
        "ts": time.time(),
        "event": "learn",
        "trace_id": trace_id,
        "task_type": body.task_type,
        "provider": body.provider,
        "ok": bool(body.ok),
        "notes": body.notes,
        "input": body.input,
        "output": body.output,
    }
    _append_jsonl(BRIDGE_LOG_PATH, rec)
    _log("learn.out", trace_id, "en", meta={"task_type": body.task_type})
    return {"ok": True, "trace_id": trace_id, "saved_to": BRIDGE_LOG_PATH}

@app.get("/bridge/logs")
def bridge_logs(limit: int = 50) -> Dict[str, Any]:
    limit = max(1, min(200, int(limit)))
    items = _safe_read_jsonl_tail(BRIDGE_LOG_PATH, limit)
    return {"ok": True, "count": len(items), "items": items, "path": BRIDGE_LOG_PATH}

@app.get("/bridge/examples")
def bridge_examples(task_type: str = "email_invoice", limit: int = 5):
    limit = max(1, min(50, int(limit)))
    examples = _load_recent_examples(task_type, limit=limit)
    return {"ok": True, "task_type": task_type, "count": len(examples), "examples": examples, "source": BRIDGE_LOG_PATH}
