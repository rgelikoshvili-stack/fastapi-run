_GEORGIAN_RE = re.compile(r'[\u10A0-\u10FF]')
_CYRILLIC_RE = re.compile(r'[\u0400-\u04FF]')
_LATIN_RE = re.compile(r'[A-Za-z]')

LANGUAGE_NAMES = {
    "ka": "Georgian",
    "ru": "Russian",
    "en": "English",
}

LANGUAGE_SYSTEM_PROMPTS = {
    "ka": (
        "You are Bridge Hub assistant. "
        "You MUST reply ONLY in Georgian. "
        "Do not mix English or Russian sentences in the answer. "
        "If code, JSON keys, API routes, URLs, emails, commands, or product names are needed, keep them exactly as-is. "
        "All explanations must be only in Georgian."
    ),
    "ru": (
        "You are Bridge Hub assistant. "
        "You MUST reply ONLY in Russian. "
        "Do not mix English or Georgian sentences in the answer. "
        "If code, JSON keys, API routes, URLs, emails, commands, or product names are needed, keep them exactly as-is. "
        "All explanations must be only in Russian."
    ),
    "en": (
        "You are Bridge Hub assistant. "
        "You MUST reply ONLY in English. "
        "Do not mix Georgian or Russian sentences in the answer. "
        "If code, JSON keys, API routes, URLs, emails, commands, or product names are needed, keep them exactly as-is."
    ),
}

def _count_scripts(text: str) -> Dict[str, int]:
    text = text or ""
    return {
        "ka": len(_GEORGIAN_RE.findall(text)),
        "ru": len(_CYRILLIC_RE.findall(text)),
        "en": len(_LATIN_RE.findall(text)),
    }

def detect_input_lang(text: str) -> str:
    counts = _count_scripts(text)
    if counts["ka"] > 0 and counts["ka"] >= counts["ru"] and counts["ka"] >= counts["en"]:
        return "ka"
    if counts["ru"] > 0 and counts["ru"] >= counts["ka"] and counts["ru"] >= counts["en"]:
        return "ru"
    return "en"

def normalize_lang(lang: Optional[str], text: str) -> str:
    lang = (lang or "").strip().lower()
    if lang in {"ka", "ru", "en"}:
        return lang
    return detect_input_lang(text)

def output_matches_lang(text: str, expected_lang: str) -> bool:
    counts = _count_scripts(text)
    total = counts["ka"] + counts["ru"] + counts["en"]

    if total == 0:
        return True

    dominant = max(counts, key=counts.get)
    if dominant == expected_lang:
        return True

    if expected_lang == "ka" and counts["ka"] >= max(counts["ru"], counts["en"]) * 0.7:
        return True
    if expected_lang == "ru" and counts["ru"] >= max(counts["ka"], counts["en"]) * 0.7:
        return True
    if expected_lang == "en" and counts["en"] >= max(counts["ka"], counts["ru"]) * 0.7:
        return True

    return False

def call_openai_lang(user_text: str, system_prompt: Optional[str] = None) -> Dict[str, Any]:
    api_key = os.getenv("OPENAI_API_KEY", "").strip()

    if not api_key:
        return {
            "provider": "openai",
            "ok": False,
            "error": "OPENAI_API_KEY not set",
            "mode": "mock",
            "text": f"[Mock] Processed: {user_text[:50]}...",
        }

    url = "https://api.openai.com/v1/chat/completions"
    headers = {
        "Authorization": f"Bearer {api_key}",
        "Content-Type": "application/json"
    }

    final_system_prompt = system_prompt or "You are a helpful assistant. Respond briefly."

    payload = {
        "model": os.getenv("OPENAI_MODEL", "gpt-4o-mini"),
        "messages": [
            {"role": "system", "content": final_system_prompt},
            {"role": "user", "content": user_text},
        ],
        "temperature": 0.2,
        "max_tokens": 500,
    }

    try:
        r = requests.post(url, json=payload, headers=headers, timeout=30)
        if r.status_code != 200:
            error_msg = r.text[:200] if r.text else f"HTTP {r.status_code}"
            return {
                "provider": "openai",
                "ok": False,
                "error": error_msg,
                "mode": "error",
                "status_code": r.status_code,
            }
        data = r.json()
        text = data["choices"][0]["message"]["content"]
        return {
            "provider": "openai",
            "ok": True,
            "text": text,
            "mode": "live",
        }
    except requests.exceptions.Timeout:
        return {
            "provider": "openai",
            "ok": False,
            "error": "Request timeout (30s)",
            "mode": "error",
        }
    except Exception as e:
        return {
            "provider": "openai",
            "ok": False,
            "error": str(e)[:200],
            "mode": "error",
        }

class ChatRequest(BaseModel):
    message: str
    threadId: Optional[str] = None
    lang: Optional[str] = None

@app.post("/chat/api")
def chat_api(req: ChatRequest):
    user_text = (req.message or "").strip()
    if not user_text:
        raise HTTPException(status_code=400, detail="message is required")

    lang = normalize_lang(req.lang, user_text)
    system_prompt = LANGUAGE_SYSTEM_PROMPTS[lang]

    result = call_openai_lang(user_text, system_prompt=system_prompt)

    answer = result.get("text") if result.get("ok") else result.get("error", "პასუხი ვერ მოვიდა")
    rewritten = False

    if result.get("ok") and answer:
        rewrite_prompt = (
            f"Rewrite the following answer in {LANGUAGE_NAMES[lang]} only. "
            f"Use strictly one language. "
            f"If even one natural-language word appears in another language, replace it. "
            f"Do not change the meaning. "
            f"Keep code, commands, JSON keys, API routes, URLs, emails, and product names exactly as-is.\n\n"
            f"{answer}"
        )
        fix = call_openai_lang(rewrite_prompt, system_prompt=system_prompt)
        fixed_text = fix.get("text", "")

        if fix.get("ok") and fixed_text:
            answer = fixed_text
            rewritten = True

    return {
        "ok": result.get("ok", False),
        "lang": lang,
        "answer": answer,
        "mode": result.get("mode"),
        "provider": result.get("provider"),
        "rewritten": rewritten,
        "threadId": req.threadId or "",
    }

