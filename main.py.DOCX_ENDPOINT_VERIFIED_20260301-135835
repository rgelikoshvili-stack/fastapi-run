import io
import pdfplumber

def parse_pdf_bank_statement(pdf_content: bytes, bank_name: str = "Unknown") -> Dict[str, Any]:
    """Parse PDF bank statement and extract transactions"""
    transactions = []
    opening_balance = None
    closing_balance = None
    period = None
    account_number = None
    
    try:
        with pdfplumber.open(io.BytesIO(pdf_content)) as pdf:
            for page_num, page in enumerate(pdf.pages):
                text = page.extract_text()
                
                # Extract account number
                if not account_number:
                    acc_match = re.search(r'Account[:\s]+(\d+)', text, re.IGNORECASE)
                    if acc_match:
                        account_number = acc_match.group(1)
                
                # Extract period
                if not period:
                    period_match = re.search(r'(January|February|March|April|May|June|July|August|September|October|November|December)\s+(\d{4})', text, re.IGNORECASE)
                    if period_match:
                        month_map = {
                            'January': '01', 'February': '02', 'March': '03',
                            'April': '04', 'May': '05', 'June': '06',
                            'July': '07', 'August': '08', 'September': '09',
                            'October': '10', 'November': '11', 'December': '12'
                        }
                        month = month_map.get(period_match.group(1), '01')
                        year = period_match.group(2)
                        period = f"{year}-{month}"
                
                # Extract tables
                tables = page.extract_tables()
                
                for table in tables:
                    if not table or len(table) < 2:
                        continue
                    
                    for row in table[1:]:
                        if not row or len(row) < 3:
                            continue
                        
                        tx = parse_transaction_row(row, bank_name)
                        if tx:
                            transactions.append(tx)
        
        if transactions:
            if not opening_balance and len(transactions) > 0:
                first_tx = transactions[0]
                if first_tx.get('balance'):
                    opening_balance = first_tx['balance'] - first_tx['amount']
            
            if not closing_balance and len(transactions) > 0:
                last_tx = transactions[-1]
                closing_balance = last_tx.get('balance', opening_balance)
        
        return {
            "ok": True,
            "transactions": transactions,
            "total_transactions": len(transactions),
            "period": period or "Unknown",
            "account_number": account_number or "Unknown",
            "opening_balance": opening_balance,
            "closing_balance": closing_balance,
            "parse_method": "pdf"
        }
        
    except Exception as e:
        return {
            "ok": False,
            "error": f"PDF parsing failed: {str(e)}",
            "transactions": [],
            "total_transactions": 0
        }


def parse_transaction_row(row: list, bank_name: str) -> Optional[Dict[str, Any]]:
    """Parse a single transaction row"""
    try:
        date_str = str(row[0]).strip() if len(row) > 0 else ""
        description = str(row[1]).strip() if len(row) > 1 else ""
        
        if not date_str or not description or date_str == "Date":
            return None
        
        date_match = re.search(r'(\d{2})[./-](\d{2})[./-](\d{4})', date_str)
        if not date_match:
            date_match = re.search(r'(\d{4})[./-](\d{2})[./-](\d{2})', date_str)
        
        if not date_match:
            return None
        
        if len(date_match.group(1)) == 4:
            date = f"{date_match.group(1)}-{date_match.group(2)}-{date_match.group(3)}"
        else:
            date = f"{date_match.group(3)}-{date_match.group(2)}-{date_match.group(1)}"
        
        debit = parse_amount(row[2]) if len(row) > 2 else 0
        credit = parse_amount(row[3]) if len(row) > 3 else 0
        balance = parse_amount(row[4]) if len(row) > 4 else None
        
        if debit > 0:
            amount = -debit
            tx_type = "debit"
        elif credit > 0:
            amount = credit
            tx_type = "credit"
        else:
            amount = parse_amount(row[2]) if len(row) > 2 else 0
            tx_type = "debit" if amount < 0 else "credit"
        
        return {
            "date": date,
            "description": description,
            "amount": amount,
            "transaction_type": tx_type,
            "balance": balance,
            "merchant": None
        }
        
    except Exception:
        return None


def parse_amount(value: any) -> float:
    """Parse amount from string"""
    if value is None:
        return 0.0
    
    amount_str = str(value).strip()
    amount_str = re.sub(r'[₾$€£\s]', '', amount_str)
    amount_str = amount_str.replace(',', '.')
    amount_str = re.sub(r'\.(?=\d{3}($|\.))', '', amount_str)
    
    try:
        return float(amount_str)
    except:
        return 0.0
def recognize_merchant(description: str) -> Dict[str, Any]:
    """Use GPT-4o to identify merchant and category from transaction description"""
    
    prompt = f"""Analyze this bank transaction description and identify:
1. Merchant name (cleaned and standardized)
2. Transaction category (e.g., office_supplies, travel, utilities, salary, etc.)
3. Likely business purpose

Transaction description: "{description}"

Return ONLY a JSON object with these fields:
- merchant: string (merchant name, null if unclear)
- category: string (transaction category)
- purpose: string (likely business purpose)

Example:
{{"merchant": "Office Supplies Inc", "category": "office_supplies", "purpose": "Business supplies"}}
"""
    
    result = call_openai(prompt)
    
    if not result.get("ok"):
        return {
            "merchant": None,
            "category": "unknown",
            "purpose": "Unknown"
        }
    
    try:
        # Parse JSON from GPT response
        import json
        text = result.get("text", "{}")
        # Remove markdown code fences if present
        text = text.replace("```json", "").replace("```", "").strip()
        parsed = json.loads(text)
        
        return {
            "merchant": parsed.get("merchant"),
            "category": parsed.get("category", "unknown"),
            "purpose": parsed.get("purpose", "Unknown")
        }
    except Exception as e:
        # Fallback if JSON parsing fails
        return {
            "merchant": None,
            "category": "unknown",
            "purpose": "Unknown",
            "error": str(e)
        }

