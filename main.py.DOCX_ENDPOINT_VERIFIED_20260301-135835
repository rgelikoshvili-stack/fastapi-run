# KNOWLEDGE BASE (PDF upload → chunks → embeddings → search)
# ============================================================

KNOWLEDGE_CHUNKS: list[dict] = []  # in-memory (Firestore შემდეგ)


def chunk_text(text: str, chunk_size: int = 500, overlap: int = 50) -> list[str]:
    """ტექსტი დავჭრათ chunks-ად"""
    words = text.split()
    chunks = []
    i = 0
    while i < len(words):
        chunk = " ".join(words[i:i + chunk_size])
        chunks.append(chunk)
        i += chunk_size - overlap
    return chunks


def get_embedding(text: str) -> list[float]:
    """OpenAI embedding"""
    api_key = os.getenv("OPENAI_API_KEY", "").strip()
    if not api_key:
        return []
    
    try:
        r = requests.post(
            "https://api.openai.com/v1/embeddings",
            headers={"Authorization": f"Bearer {api_key}", "Content-Type": "application/json"},
            json={"model": "text-embedding-3-small", "input": text},
            timeout=30,
        )
        return r.json()["data"][0]["embedding"]
    except Exception as e:
        return []


def cosine_similarity(a: list[float], b: list[float]) -> float:
    import numpy as np
    a, b = np.array(a), np.array(b)
    if np.linalg.norm(a) == 0 or np.linalg.norm(b) == 0:
        return 0.0
    return float(np.dot(a, b) / (np.linalg.norm(a) * np.linalg.norm(b)))


@app.post("/knowledge/upload", response_model=Dict[str, Any])
async def knowledge_upload(
    file: UploadFile = File(...),
    doc_name: Optional[str] = Form(None)
):
    """PDF ატვირთვა → chunks → embeddings → შენახვა"""
    if not file.filename.lower().endswith(".pdf"):
        raise HTTPException(status_code=400, detail="მხოლოდ PDF")

    raw = await file.read()
    text = extract_text_from_pdf_bytes(raw)

    if not text.strip():
        raise HTTPException(status_code=400, detail="PDF-ში ტექსტი ვერ მოიძებნა")

    name = doc_name or file.filename
    chunks = chunk_text(text)
    
    saved = 0
    for i, chunk in enumerate(chunks):
        embedding = get_embedding(chunk)
        chunk_id = str(uuid.uuid4())
        KNOWLEDGE_CHUNKS.append({
            "chunk_id": chunk_id,
            "doc_name": name,
            "chunk_index": i,
            "text": chunk,
            "embedding": embedding,
            "uploaded_at": datetime.now(timezone.utc).isoformat(),
        })
        saved += 1

    store_event({
        "kind": "knowledge_upload",
        "doc_name": name,
        "chunks": saved,
    })

    return {
        "ok": True,
        "doc_name": name,
        "chunks_saved": saved,
        "total_chars": len(text),
    }


@app.post("/knowledge/search", response_model=Dict[str, Any])
def knowledge_search(payload: Dict[str, Any]):
    """კითხვაზე შესაბამისი chunks დაბრუნება"""
    query = payload.get("query", "")
    top_k = payload.get("top_k", 5)

    if not query:
        raise HTTPException(status_code=400, detail="query საჭიროა")

    if not KNOWLEDGE_CHUNKS:
        return {"ok": True, "results": [], "message": "Knowledge base ცარიელია"}

    query_emb = get_embedding(query)
    if not query_emb:
        # fallback: keyword search
        results = []
        for chunk in KNOWLEDGE_CHUNKS:
            if query.lower() in chunk["text"].lower():
                results.append({
                    "doc_name": chunk["doc_name"],
                    "chunk_index": chunk["chunk_index"],
                    "text": chunk["text"][:500],
                    "score": 1.0,
                })
        return {"ok": True, "results": results[:top_k], "method": "keyword"}

    scored = []
    for chunk in KNOWLEDGE_CHUNKS:
        if chunk.get("embedding"):
            score = cosine_similarity(query_emb, chunk["embedding"])
            scored.append({
                "doc_name": chunk["doc_name"],
                "chunk_index": chunk["chunk_index"],
                "text": chunk["text"][:500],
                "score": round(score, 4),
            })

    scored.sort(key=lambda x: x["score"], reverse=True)

    store_event({
        "kind": "knowledge_search",
        "query": query[:100],
        "results": len(scored[:top_k]),
    })

    return {"ok": True, "results": scored[:top_k], "method": "semantic"}


@app.get("/knowledge/list", response_model=Dict[str, Any])
def knowledge_list():
    """ატვირთული დოკუმენტების სია"""
    docs: Dict[str, int] = {}
    for chunk in KNOWLEDGE_CHUNKS:
        name = chunk["doc_name"]
        docs[name] = docs.get(name, 0) + 1

    return {
        "ok": True,
        "total_chunks": len(KNOWLEDGE_CHUNKS),
        "documents": [{"doc_name": k, "chunks": v} for k, v in docs.items()],
    }








