@app.post("/bank/upload", response_model=Dict[str, Any])
def upload_bank_statement(payload: Dict[str, Any]):
    """Upload and parse bank statement (PDF/CSV/Excel)"""
    
    file_type = payload.get("file_type", "pdf")
    file_content = payload.get("file_content")  # base64 encoded
    bank_name = payload.get("bank_name", "Unknown")
    
    if not file_content:
        return {
            "ok": False,
            "error": "file_content is required (base64 encoded)",
            "total_transactions": 0
        }
    
    try:
        # Decode base64
        import base64
        content_bytes = base64.b64decode(file_content)
        
        # Route to appropriate parser
        if file_type == "pdf":
            result = parse_pdf_bank_statement(content_bytes, bank_name)
        elif file_type == "csv":
            # CSV parser (simple version for now)
            result = {
                "ok": True,
                "transactions": [],
                "total_transactions": 0,
                "parse_method": "csv",
                "message": "CSV parsing not fully implemented yet"
            }
        elif file_type == "xlsx":
            result = parse_excel_bank_statement(content_bytes, bank_name)
        else:
            return {
                "ok": False,
                "error": f"Unsupported file type: {file_type}",
                "total_transactions": 0
            }
        
        # Add statement_id and bank_name
        result["statement_id"] = str(uuid.uuid4())
        result["bank_name"] = bank_name
        
        # Store in memory
        BANK_STATEMENTS.append(result)
        
        # Log event
        store_event({
            "kind": "bank_statement_uploaded",
            "statement_id": result["statement_id"],
            "file_type": file_type,
            "bank_name": bank_name,
            "total_transactions": result.get("total_transactions", 0)
        })
        
        return result
        
    except Exception as e:
        return {
            "ok": False,
            "error": f"Upload failed: {str(e)}",
            "total_transactions": 0
        }
    
    return result

