        data = raw["data"]

    task_type = (
        request.query_params.get("task_type")
        or raw.get("task_type")
        or data.get("task_type")
        or getattr(body, "task_type", None)
    )

    if task_type == "email_invoice":
        payload = {
            "from_field": data.get("from_field") or data.get("from") or raw.get("from_field") or raw.get("from"),
            "subject": data.get("subject") or raw.get("subject"),
            "body": (
                data.get("body")
                or data.get("text")
                or raw.get("body")
                or raw.get("text")
                or (getattr(body, "text", None) or "")
            ),
        }
        _log("email_invoice.classify", trace_id=trace_id, meta={"via": "bridge_classify"})
        result = _ei_classify_email_invoice(payload, trace_id)
        return {"ok": True, "trace_id": trace_id, "result": result}
    # END EMAIL_INVOICE_CLASSIFY_BRANCH

    # --- LLM classify branch (optional) ---
    mode = (os.getenv("CLASSIFY_MODE", "") or "").strip().lower()
    if mode in ("llm", "openai", "gpt"):
        text_in = str(data.get("text") or data.get("memo") or getattr(body, "text", None) or "").strip()
        if text_in:
            llm = _classify_llm(text_in, trace_id)
            if isinstance(llm, dict) and llm:
                # merge + keep original text
                data = {**data, **llm, "text": text_in}
            # continue into rules below to fill missing fields

            else:
                try:
                    _log("bridge.classify.llm_empty", trace_id, {"mode": mode})
                except Exception:
                    pass
    # --- end LLM branch ---
    memo_raw = str(data.get("memo") or data.get("text") or getattr(body, "text", None) or "").strip()
    vendor_raw = str(data.get("vendor") or "").strip()
    amount = data.get("amount")
    currency = str(data.get("currency") or "").strip()
    country = (body.country or "GE").upper()

    memo = memo_raw.lower()
    vendor = vendor_raw.upper()

    category = "OTHER"
    account_code = "9999"
    confidence = 0.55

    # simple rules first
    fuel_vendors = {"WISSOL", "SOCAR", "GULF", "LUKOIL", "ROMPETROL"}
    fuel_keywords = ("საწვ", "ბენზ", "დიზელ", "fuel", "diesel", "gas")
    if any(k in memo for k in fuel_keywords) or (vendor in fuel_vendors):
        category = "FUEL"
        account_code = "7420"
        confidence = 0.78
    elif ("coffee" in memo) or ("ყავა" in memo) or (vendor in {"COFFEELAB", "DUNKIN"}):
        category = "FOOD_CAFE"
        account_code = "6120"
        confidence = 0.70
    elif vendor in {"SPAR", "CARREFOUR", "NIKORA", "ORINABJI"} or ("grocery" in memo) or ("სუპ" in memo):
        category = "FOOD_GROCERY"
        account_code = "6110"
        confidence = 0.72

    # VAT (GE only)
    vat_rate = 0.18 if country == "GE" else 0.0
    vat_amount = 0.0
    try:
        amt = float(amount) if amount is not None else 0.0
        if vat_rate > 0 and amt > 0:
            vat_amount = round(amt * vat_rate / (1 + vat_rate), 2)
    except Exception:
        pass

    result = {
        **data,
        "vendor": vendor_raw,
        "memo": memo_raw,
        "amount": amount,
        "currency": currency,
        "category": category,
        "account_code": account_code,
        "confidence": float(confidence),
        "vat": {"rate": float(vat_rate), "amount": float(vat_amount)},
    }

    _log("bridge.classify", trace_id, {"category": category, "account_code": account_code})
    return {"ok": True, "trace_id": trace_id, "result": result}

@app.post("/bridge/learn")
async def bridge_learn(payload: dict, request: Request):
    trace_id = payload.get("trace_id") or str(uuid.uuid4())
    task_type = payload.get("task_type") or "email_invoice"
    provider = payload.get("provider") or "manus"
    dedup_key = payload.get("dedup_key") or trace_id

    use_firestore = os.getenv("USE_FIRESTORE", "0").lower() in ("1", "true", "yes")
    if use_firestore:
        from google.cloud import firestore
        from google.api_core.exceptions import AlreadyExists

        db = firestore.Client()
        coll = db.collection(os.getenv("FIRESTORE_COLLECTION", "bridge_logs"))

        doc_id = str(dedup_key).replace("/", "_")
        data = {
            "ts": firestore.SERVER_TIMESTAMP,
            "event": "learn",
            "trace_id": trace_id,
            "task_type": task_type,
            "provider": provider,
            "ok": True,
            "notes": payload.get("notes", ""),
            "input": payload.get("input"),
            "output": payload.get("output"),
            "dedup_key": payload.get("dedup_key"),
            "meta": payload.get("meta") or {},
            "ip": getattr(request.client, "host", None),
        }
        try:
            coll.document(doc_id).create(data)
            duplicate = False
        except AlreadyExists:
            duplicate = True

        return {"ok": True, "trace_id": trace_id, "saved_to": f"firestore:{doc_id}", "duplicate": duplicate}

    # fallback: local jsonl (ephemeral on Cloud Run)
    log_path = os.getenv("BRIDGE_LOG_PATH", "/tmp/bridge_logs.jsonl")
    row = {
        "ts": time.time(),
        "event": "learn",
        "trace_id": trace_id,
        "task_type": task_type,
        "provider": provider,
        "ok": True,
        "notes": payload.get("notes", ""),
        "input": payload.get("input"),
        "output": payload.get("output"),
        "dedup_key": payload.get("dedup_key"),
    }
    os.makedirs(os.path.dirname(log_path), exist_ok=True)
    with open(log_path, "a", encoding="utf-8") as f:
        f.write(json.dumps(row, ensure_ascii=False) + "\n")

    return {"ok": True, "trace_id": trace_id, "saved_to": f"file:{log_path}"}

@app.get("/bridge/examples")
async def bridge_examples(task_type: str = "email_invoice", limit: int = 20):
    limit = int(limit or 20)
    limit = max(1, min(limit, 200))

    use_firestore = os.getenv("USE_FIRESTORE", "0").lower() in ("1", "true", "yes")
    if use_firestore:
        from google.cloud import firestore

        db = firestore.Client()
        coll = db.collection(os.getenv("FIRESTORE_COLLECTION", "bridge_logs"))

        q = (
            coll.where("task_type", "==", task_type)
            .order_by("ts", direction=firestore.Query.DESCENDING)
            .limit(limit)
        )

        examples = []
        for doc in q.stream():
            d = doc.to_dict()
            if "ts" in d and hasattr(d["ts"], "isoformat"):
                d["ts"] = d["ts"].isoformat()
            examples.append(d)

        return {"ok": True, "task_type": task_type, "count": len(examples), "examples": examples, "source": "firestore"}

    # fallback file jsonl
    log_path = os.getenv("BRIDGE_LOG_PATH", "/tmp/bridge_logs.jsonl")
    if not os.path.exists(log_path):
        return {"ok": True, "task_type": task_type, "count": 0, "examples": [], "source": "file", "path": log_path}

    rows = []
    with open(log_path, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                row = json.loads(line)
            except Exception:
                continue
            if row.get("task_type") == task_type:
                rows.append(row)

    rows.sort(key=lambda x: x.get("ts", 0), reverse=True)
    rows = rows[:limit]
    return {"ok": True, "task_type": task_type, "count": len(rows), "examples": rows, "source": "file", "path": log_path}


