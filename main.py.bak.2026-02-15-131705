@app.post("/bridge/classify")
def bridge_classify(body: ValidateBody, request: Request) -> Dict[str, Any]:
    trace_id = str(uuid.uuid4())
    lang = pick_lang(request, body.locale)
    country = (body.country or "").upper()

    data = body.data if isinstance(body.data, dict) else {}
    keys = list(data.keys())
    _log("bridge.classify.in", trace_id=trace_id, lang=lang, country=country, keys=keys)

    vendor = str(data.get("vendor") or "").strip().upper()
    memo = str(data.get("memo") or "").strip().lower()    # Decide category/account using OpenAI (if configured); fallback to simple rules
    category = "OTHER"
    account_code = "9999"
    confidence = 0.55

    llm = None
    try:
        llm = llm_classify_transaction(lang=lang, country=country, data=data)
    except Exception as e:
        _log("bridge.classify.llm_error", trace_id=trace_id, lang=lang, country=country, keys=[f"err:{str(e)[:200]}"])

    if isinstance(llm, dict) and llm.get("ok"):
        category = llm.get("category") or category
        account_code = llm.get("account_code") or account_code
        try:
            confidence = float(llm.get("confidence", confidence))
        except Exception:
            pass
    else:
        # Fallback rules (cheap)
        if "coffee" in memo or "კაფე" in memo or vendor in {"COFFEELAB", "DUNKIN"}:
            category = "FOOD_CAFE"
            account_code = "6120"
            confidence = 0.70
        elif vendor in {"SPAR", "CARREFOUR", "NIKORA", "ORINABJI"} or ("grocery" in memo) or ("სუპ" in memo):
            category = "FOOD_GROCERY"
            account_code = "6110"
            confidence = 0.72

    # VAT mock (GE: assume amount includes 18% VAT)
    vat_rate = 0.18 if country == "GE" else 0.0
    vat_amount = 0.0
    try:
        amt = float(data.get("amount"))
        if vat_rate > 0 and amt > 0:
            vat_amount = round(amt * vat_rate / (1 + vat_rate), 2)
    except Exception:
        pass

    result = {
        **data,
        "category": category,
        "account_code": account_code,
        "vat": {"rate": vat_rate, "amount": vat_amount},
        "confidence": confidence,
    }

    return {"ok": True, "trace_id": trace_id, "lang": lang, "result": result}


@app.get("/debug/log")
def debug_log(limit: int = 10) -> Dict[str, Any]:
    try:
        lim = int(limit)
    except Exception:
        lim = 10
    lim = max(1, min(lim, 100))
    return {"ok": True, "limit": lim, "items": LOGS[-lim:]}
