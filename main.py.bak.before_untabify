                        model=model,
                        input=[
                            {"role": "system", "content": sys_prompt},
                            {"role": "user", "content": memo_raw},
                        ],
                        temperature=0,
                    )
                    out_text = getattr(resp, "output_text", None)
                    if not out_text:
                        # sometimes output is in resp.output list
                        out = getattr(resp, "output", None) or []
                        # best-effort concat
                        parts = []
                        for item in out:
                            content = getattr(item, "content", None) or []
                            for c in content:
                                t = getattr(c, "text", None)
                                if t:
                                    parts.append(t)
                        out_text = "\n".join(parts).strip() if parts else None
                except Exception:
                    out_text = None

                if not out_text:
                    cc = client.chat.completions.create(
                        model=model,
                        messages=[
                            {"role": "system", "content": sys_prompt},
                            {"role": "user", "content": memo_raw},
                        ],
                        temperature=0,
                    )
                    out_text = (cc.choices[0].message.content or "").strip()

                parsed = _extract_json(out_text)
                if isinstance(parsed, dict):
                    llm_used = False
                    v = parsed.get("vendor")
                    a = parsed.get("amount")
                    c = parsed.get("currency")
                    vr = parsed.get("vat_rate")
                    va = parsed.get("vat_amount")

                    if (not vendor_raw) and isinstance(v, str) and v.strip():
                        vendor_raw = v.strip()
                    if amount is None and isinstance(a, (int, float)):
                        amount = float(a)
                    if (not currency) and isinstance(c, str) and c.strip():
                        currency = c.strip().upper()
                    # temporarily store VAT extraction
                    extracted_vat_rate = float(vr) if isinstance(vr, (int, float)) else None
                    extracted_vat_amount = float(va) if isinstance(va, (int, float)) else None
                else:
                    extracted_vat_rate = None
                    extracted_vat_amount = None
            except Exception as e:
                extracted_vat_rate = None
                extracted_vat_amount = None
                llm_error = str(e)
        else:
            extracted_vat_rate = None
            extracted_vat_amount = None
    else:
        extracted_vat_rate = None
        extracted_vat_amount = None

    memo = memo_raw.lower()
    vendor_upper = vendor_raw.upper()

    category = "OTHER"
    account_code = "6000"
    confidence = 0.75

    # simple rules
    fuel_vendors = {"WISSOL", "SOCAR", "GULF", "LUKOIL", "ROMPETROL"}
    fuel_keywords = ("საწვ", "ბენზ", "დიზელ", "fuel", "diesel", "gas")
    if any(k in memo for k in fuel_keywords) or (vendor_upper in fuel_vendors):
        category = "FUEL"
        account_code = "7420"
        confidence = 0.78
    elif ("coffee" in memo) or ("ყავა" in memo) or (vendor_upper in {"COFFEELAB", "DUNKIN"}):
        category = "FOOD_CAFE"
        account_code = "6120"
        confidence = 0.70
    elif vendor_upper in {"SPAR", "CARREFOUR", "NIKORA", "ORINABJI"} or ("grocery" in memo) or ("სუპ" in memo):
        category = "FOOD_GROCERY"
        account_code = "6110"
        confidence = 0.72

    # VAT
    default_vat_rate = 0.18 if country == "GE" else 0.0
    vat_rate = extracted_vat_rate if extracted_vat_rate is not None else default_vat_rate

    vat_amount = 0.0
    try:
        if extracted_vat_amount is not None and extracted_vat_amount > 0:
            vat_amount = round(float(extracted_vat_amount), 2)
        else:
            amt = float(amount) if amount is not None else 0.0
            if vat_rate > 0 and amt > 0:
                vat_amount = round(amt * vat_rate / (1 + vat_rate), 2)
    except Exception:
        pass

    result = {
        **data,
        "vendor": vendor_raw,
        "memo": memo_raw,
        "amount": amount,
        "currency": currency,
        "category": category,
        "account_code": account_code,
        "confidence": float(confidence),
        "vat": {"rate": float(vat_rate), "amount": float(vat_amount)},
        "llm_used": bool(llm_used),
    }
    if llm_error:
        result["llm_error"] = llm_error

    _log("bridge.classify", trace_id, {"category": category, "account_code": account_code, "llm_used": llm_used})
    return {"ok": True, "trace_id": trace_id, "result": result}

@app.post("/bridge/learn")
async def bridge_learn(payload: dict, request: Request):
    trace_id = payload.get("trace_id") or str(uuid.uuid4())
    task_type = payload.get("task_type") or "email_invoice"
    provider = payload.get("provider") or "manus"
    dedup_key = payload.get("dedup_key") or trace_id

    use_firestore = os.getenv("USE_FIRESTORE", "0").lower() in ("1", "true", "yes")
    if use_firestore:
        from google.cloud import firestore
        from google.api_core.exceptions import AlreadyExists

        db = firestore.Client()
        coll = db.collection(os.getenv("FIRESTORE_COLLECTION", "bridge_logs"))

        doc_id = str(dedup_key).replace("/", "_")
        data = {
            "ts": firestore.SERVER_TIMESTAMP,
            "event": "learn",
            "trace_id": trace_id,
            "task_type": task_type,
            "provider": provider,
            "ok": True,
            "notes": payload.get("notes", ""),
            "input": payload.get("input"),
            "output": payload.get("output"),
            "dedup_key": payload.get("dedup_key"),
            "meta": payload.get("meta") or {},
            "ip": getattr(request.client, "host", None),
        }
        try:
            coll.document(doc_id).create(data)
            duplicate = False
        except AlreadyExists:
            duplicate = True

        return {"ok": True, "trace_id": trace_id, "saved_to": f"firestore:{doc_id}", "duplicate": duplicate}

    # fallback: local jsonl (ephemeral on Cloud Run)
    log_path = os.getenv("BRIDGE_LOG_PATH", "/tmp/bridge_logs.jsonl")
    row = {
        "ts": time.time(),
        "event": "learn",
        "trace_id": trace_id,
        "task_type": task_type,
        "provider": provider,
        "ok": True,
        "notes": payload.get("notes", ""),
        "input": payload.get("input"),
        "output": payload.get("output"),
        "dedup_key": payload.get("dedup_key"),
    }
    os.makedirs(os.path.dirname(log_path), exist_ok=True)
    with open(log_path, "a", encoding="utf-8") as f:
        f.write(json.dumps(row, ensure_ascii=False) + "\n")

    return {"ok": True, "trace_id": trace_id, "saved_to": f"file:{log_path}"}

@app.get("/bridge/examples")
async def bridge_examples(task_type: str = "email_invoice", limit: int = 20):
    limit = int(limit or 20)
    limit = max(1, min(limit, 200))

    use_firestore = os.getenv("USE_FIRESTORE", "0").lower() in ("1", "true", "yes")
    if use_firestore:
        from google.cloud import firestore

        db = firestore.Client()
        coll = db.collection(os.getenv("FIRESTORE_COLLECTION", "bridge_logs"))

        q = (
            coll.where("task_type", "==", task_type)
            .order_by("ts", direction=firestore.Query.DESCENDING)
            .limit(limit)
        )

        examples = []
        for doc in q.stream():
            d = doc.to_dict()
            if "ts" in d and hasattr(d["ts"], "isoformat"):
                d["ts"] = d["ts"].isoformat()
            examples.append(d)

        return {"ok": True, "task_type": task_type, "count": len(examples), "examples": examples, "source": "firestore"}

    # fallback file jsonl
    log_path = os.getenv("BRIDGE_LOG_PATH", "/tmp/bridge_logs.jsonl")
    if not os.path.exists(log_path):
        return {"ok": True, "task_type": task_type, "count": 0, "examples": [], "source": "file", "path": log_path}

    rows = []
    with open(log_path, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                row = json.loads(line)
            except Exception:
                continue
            if row.get("task_type") == task_type:
                rows.append(row)

    rows.sort(key=lambda x: x.get("ts", 0), reverse=True)
    rows = rows[:limit]
    return {"ok": True, "task_type": task_type, "count": len(rows), "examples": rows, "source": "file", "path": log_path}


