_BRIDGE_LEARN_COL = os.getenv("BRIDGE_LEARN_COLLECTION", "bridge_learn_v1")
_BRIDGE_FEEDBACK_COL = os.getenv("BRIDGE_FEEDBACK_COLLECTION", "bridge_feedback_v1")

def _norm_text(s: str) -> str:
    return " ".join((s or "").strip().split()).lower()

def _fingerprint(task_type: str, text: str) -> str:
    h = hashlib.sha1()
    h.update((task_type or "").encode("utf-8"))
    h.update(b"|")
    h.update(_norm_text(text).encode("utf-8"))
    return h.hexdigest()

def memory_lookup(task_type: str, text: str) -> Optional[Dict[str, Any]]:
    """Exact-match memory lookup by fingerprint."""
    if _fs_client is None:
        return None
    fp = _fingerprint(task_type, text)
    doc_id = f"{task_type}:{fp}"
    doc = _fs_client.collection(_BRIDGE_LEARN_COL).document(doc_id).get()
    if not doc.exists:
        return None
    data = doc.to_dict() or {}
    label = data.get("label")
    if isinstance(label, dict):
        # mark as learned result
        label = dict(label)
        label["learned"] = True
        label["memory_id"] = doc_id
        return label
    return None

def memory_upsert(task_type: str, text: str, label: Dict[str, Any], meta: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
    """Store/update a learning example in Firestore."""
    if _fs_client is None:
        return {"ok": False, "error": "firestore_not_available"}
    fp = _fingerprint(task_type, text)
    doc_id = f"{task_type}:{fp}"
    now = datetime.now(timezone.utc).isoformat()
    payload = {
        "task_type": task_type,
        "fingerprint": fp,
        "text": text,
        "label": label,
        "meta": meta or {},
        "updated_at": now,
    }
    _fs_client.collection(_BRIDGE_LEARN_COL).document(doc_id).set(payload, merge=True)
    return {"ok": True, "doc_id": doc_id}

def feedback_store(trace_id: str, task_type: str, text: str, correct: Dict[str, Any], meta: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
    """Store correction feedback (and also upsert into learn set)."""
    if _fs_client is None:
        return {"ok": False, "error": "firestore_not_available"}
    now = datetime.now(timezone.utc).isoformat()
    fb = {
        "trace_id": trace_id,
        "task_type": task_type,
        "text": text,
        "correct": correct,
        "meta": meta or {},
        "created_at": now,
    }
    _fs_client.collection(_BRIDGE_FEEDBACK_COL).document(f"{trace_id}").set(fb, merge=True)
    # also learn from feedback
    memory_upsert(task_type, text, correct, meta=meta)
    return {"ok": True}
