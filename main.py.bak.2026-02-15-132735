from fastapi import FastAPI, Request
from pydantic import BaseModel
from typing import Any, Dict, List, Optional
import json
import os
import time
import uuid
import re

try:
    from openai import OpenAI
except Exception:
    OpenAI = None

app = FastAPI(title="AI Bridge API", version="0.3.4")

LOGS: List[Dict[str, Any]] = []

I18N: Dict[str, Dict[str, str]] = {
    "en": {"root": "FastAPI is running on Cloud Run", "validated": "validated"},
    "ka": {"root": "FastAPI მუშაობს Cloud Run-ზე", "validated": "ვალიდაცია გავლილია"},
    "ru": {"root": "FastAPI работает на Cloud Run", "validated": "проверка пройдена"},
}

def _log(event: str, trace_id: str, lang: str, country: str = "", keys: Optional[List[str]] = None) -> None:
    rec = {"ts": time.time(), "event": event, "trace_id": trace_id, "lang": lang, "country": country, "keys": keys or []}
    LOGS.append(rec)
    if len(LOGS) > 500:
        del LOGS[:100]

def pick_lang(request: Request, body_locale: Optional[str] = None, default: str = "en") -> str:
    if body_locale:
        bl = body_locale.lower()
        if bl in I18N:
            return bl
    q = request.query_params.get("lang")
    if q:
        ql = q.lower()
        if ql in I18N:
            return ql
    return default

@app.get("/health")
def health() -> Dict[str, Any]:
    return {"ok": True}

@app.get("/")
def root(request: Request) -> Dict[str, Any]:
    lang = pick_lang(request)
    return {"status": "ok", "message": I18N[lang]["root"], "lang": lang}

class ValidateBody(BaseModel):
    locale: Optional[str] = None
    country: Optional[str] = None
    data: Optional[Dict[str, Any]] = None
    text: Optional[str] = None

def llm_classify_transaction(lang: str, country: str, tx: Dict[str, Any]) -> Dict[str, Any]:
    api_key = (os.getenv("OPENAI_API_KEY") or "").strip()
    if not api_key:
        return {"ok": False, "error": "no_api_key"}
    if OpenAI is None:
        return {"ok": False, "error": "openai_pkg_missing"}

    model = (os.getenv("OPENAI_MODEL") or "gpt-4o-mini").strip()

    system = (
        "You are an accounting classifier. "
        "Return ONLY valid JSON with keys: category (string), account_code (string), confidence (number 0..1). "
        "No extra text."
    )

    user = {
        "country": (country or "").upper(),
        "lang": lang,
        "tx": tx,
        "rules": {
            "examples": [
                {"when": "fuel/benz/diesel", "category": "FUEL", "account_code": "7420"},
                {"when": "coffee/cafe", "category": "FOOD_CAFE", "account_code": "6120"},
                {"when": "grocery/supermarket", "category": "FOOD_GROCERY", "account_code": "6110"},
            ],
            "fallback": {"category": "OTHER", "account_code": "9999"},
        },
    }

    client = OpenAI(api_key=api_key)
    resp = client.chat.completions.create(
        model=model,
        messages=[
            {"role": "system", "content": system},
            {"role": "user", "content": json.dumps(user, ensure_ascii=False)},
        ],
        temperature=0.1,
        response_format={"type": "json_object"},
    )

    text = (resp.choices[0].message.content or "").strip()
    obj = json.loads(text)

    category = str(obj.get("category") or "OTHER").strip().upper()
    account_code = str(obj.get("account_code") or "9999").strip()

    try:
        confidence = float(obj.get("confidence", 0.60))
    except Exception:
        confidence = 0.60
    confidence = max(0.0, min(1.0, confidence))

    if not re.fullmatch(r"[A-Z0-9_]{2,40}", category or ""):
        category = "OTHER"
    if not re.fullmatch(r"[0-9]{3,10}", account_code or ""):
        account_code = "9999"

    return {"ok": True, "category": category, "account_code": account_code, "confidence": confidence}

@app.post("/bridge/classify")
def bridge_classify(body: ValidateBody, request: Request) -> Dict[str, Any]:
    trace_id = str(uuid.uuid4())
    lang = pick_lang(request, body.locale)
    country = (body.country or "").upper()

    data = body.data or {}
    memo_raw = str(data.get("memo") or body.text or "").strip()
    vendor_raw = str(data.get("vendor") or "").strip()
    amount = data.get("amount")
    currency = str(data.get("currency") or "").strip()
    date = str(data.get("date") or "").strip()

    memo = memo_raw.lower()
    vendor = vendor_raw.upper()

    category = "OTHER"
    account_code = "9999"
    confidence = 0.55

    llm = None
    try:
        llm = llm_classify_transaction(
            lang=lang,
            country=country,
            tx={"vendor": vendor_raw, "memo": memo_raw, "amount": amount, "currency": currency, "date": date},
        )
    except Exception as e:
        _log("bridge.classify.llm_error", trace_id=trace_id, lang=lang, country=country, keys=[f"err:{str(e)[:200]}"])

    if isinstance(llm, dict) and llm.get("ok"):
        category = llm.get("category") or category
        account_code = llm.get("account_code") or account_code
        try:
            confidence = float(llm.get("confidence", confidence))
        except Exception:
            pass
    else:
        fuel_vendors = {"WISSOL", "SOCAR", "GULF", "LUKOIL", "ROMPETROL"}
        fuel_keywords = ("საწვ", "ბენზ", "დიზელ", "fuel", "diesel", "gas")

        if any(k in memo for k in fuel_keywords) or (vendor in fuel_vendors):
            category = "FUEL"
            account_code = "7420"
            confidence = 0.78
        elif ("coffee" in memo) or ("ყავა" in memo) or (vendor in {"COFFEELAB", "DUNKIN"}):
            category = "FOOD_CAFE"
            account_code = "6120"
            confidence = 0.70
        elif vendor in {"SPAR", "CARREFOUR", "NIKORA", "ORINABJI"} or ("grocery" in memo) or ("სუპ" in memo):
            category = "FOOD_GROCERY"
            account_code = "6110"
            confidence = 0.72

    vat_rate = 0.18 if country == "GE" else 0.0
    vat_amount = 0.0
    try:
        amt = float(amount) if amount is not None else 0.0
        if vat_rate > 0 and amt > 0:
            vat_amount = round(amt * vat_rate / (1 + vat_rate), 2)
    except Exception:
        pass

    result = {
        **data,
        "vendor": vendor_raw,
        "memo": memo_raw,
        "category": str(category).upper(),
        "account_code": str(account_code),
        "confidence": float(max(0.0, min(1.0, confidence))),
        "vat": {"rate": float(vat_rate), "amount": float(vat_amount)},
    }

    _log("bridge.classify.out", trace_id=trace_id, lang=lang, country=country, keys=[f"cat:{result['category']}", f"acc:{result['account_code']}"])
    return {"ok": True, "trace_id": trace_id, "lang": lang, "result": result}
