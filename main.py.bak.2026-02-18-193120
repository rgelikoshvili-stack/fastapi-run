@app.post("/bridge/classify")
def bridge_classify(body: BridgeBody, request: Request) -> Dict[str, Any]:
    trace_id = str(uuid.uuid4())
    data = body.data if isinstance(body.data, dict) else {}
    # BEGIN EMAIL_INVOICE_CLASSIFY_BRANCH
    if (request.query_params.get("task_type") or getattr(req, "task_type", None)) == "email_invoice":
        result = _ei_classify_email_invoice(payload, trace_id)
        return {"ok": True, "trace_id": trace_id, "result": result}
    # END EMAIL_INVOICE_CLASSIFY_BRANCH
    memo_raw = str(data.get("memo") or body.text or "").strip()
    vendor_raw = str(data.get("vendor") or "").strip()
    amount = data.get("amount")
    currency = str(data.get("currency") or "").strip()
    country = (body.country or "GE").upper()

    memo = memo_raw.lower()
    vendor = vendor_raw.upper()

    category = "OTHER"
    account_code = "9999"
    confidence = 0.55

    # simple rules first
    fuel_vendors = {"WISSOL", "SOCAR", "GULF", "LUKOIL", "ROMPETROL"}
    fuel_keywords = ("საწვ", "ბენზ", "დიზელ", "fuel", "diesel", "gas")
    if any(k in memo for k in fuel_keywords) or (vendor in fuel_vendors):
        category = "FUEL"
        account_code = "7420"
        confidence = 0.78
    elif ("coffee" in memo) or ("ყავა" in memo) or (vendor in {"COFFEELAB", "DUNKIN"}):
        category = "FOOD_CAFE"
        account_code = "6120"
        confidence = 0.70
    elif vendor in {"SPAR", "CARREFOUR", "NIKORA", "ORINABJI"} or ("grocery" in memo) or ("სუპ" in memo):
        category = "FOOD_GROCERY"
        account_code = "6110"
        confidence = 0.72

    # VAT (GE only)
    vat_rate = 0.18 if country == "GE" else 0.0
    vat_amount = 0.0
    try:
        amt = float(amount) if amount is not None else 0.0
        if vat_rate > 0 and amt > 0:
            vat_amount = round(amt * vat_rate / (1 + vat_rate), 2)
    except Exception:
        pass

    result = {
        **data,
        "vendor": vendor_raw,
        "memo": memo_raw,
        "amount": amount,
        "currency": currency,
        "category": category,
        "account_code": account_code,
        "confidence": float(confidence),
        "vat": {"rate": float(vat_rate), "amount": float(vat_amount)},
    }

    _log("bridge.classify", trace_id, {"category": category, "account_code": account_code})
    return {"ok": True, "trace_id": trace_id, "result": result}

@app.post("/bridge/learn")
def bridge_learn(body: LearnBody) -> Dict[str, Any]:
    trace_id = str(uuid.uuid4())
    rec = {
        "ts": time.time(),
        "event": "learn",
        "trace_id": trace_id,
        "task_type": body.task_type,
        "provider": body.provider,
        "ok": bool(body.ok),
        "notes": body.notes or "",
        "input": body.input,
        "output": body.output,
    }
    _append_jsonl(BRIDGE_LOG_PATH, rec)
    _log("bridge.learn", trace_id, {"task_type": body.task_type, "path": BRIDGE_LOG_PATH})
    return {"ok": True, "trace_id": trace_id, "saved_to": BRIDGE_LOG_PATH}

