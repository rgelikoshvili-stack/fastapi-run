def _normalize_vat(vat_obj, amount, country: str):
    """
    Normalize vat.rate to decimal (0.18), recompute vat.amount for GE when possible.
    Assumption: amount is TOTAL incl VAT (common for receipts/invoices).
    """
    try:
        country = (country or "GE").upper()
    except Exception:
        country = "GE"

    if not isinstance(vat_obj, dict):
        vat_obj = {}

    rate = vat_obj.get("rate")
    amt = vat_obj.get("amount")

    # normalize rate: 18 -> 0.18
    try:
        if rate is not None:
            r = float(rate)
            if r > 1.0:
                r = r / 100.0
            rate = r
    except Exception:
        rate = None

    # recompute amount for GE if amount exists and rate looks valid
    try:
        total = float(amount) if amount is not None else None
    except Exception:
        total = None

    if country == "GE":
        # default to 18% if missing but hints exist later (keep only if already provided)
        if rate is None:
            pass
        # compute vat portion from gross total
        if total is not None and rate in (0.18, 0.0):
            if rate == 0.18:
                vat_calc = round(total * rate / (1.0 + rate), 2)
            else:
                vat_calc = 0.0
            # if amt missing or wildly off -> replace
            try:
                if amt is None or abs(float(amt) - vat_calc) > max(1.0, vat_calc * 0.25):
                    amt = vat_calc
            except Exception:
                amt = vat_calc

    return {"rate": float(rate) if rate is not None else None, "amount": float(amt) if amt is not None else None}


def _classify_llm(text: str, trace_id: str) -> dict:
    key = (os.getenv("OPENAI_API_KEY", "") or "").strip()
    if not key:
        return {}

    model = os.getenv("OPENAI_MODEL", "gpt-4o-mini")
    sys_prompt = (
        "You are an accounting transaction classifier for Georgia (GEL/VAT 18%). "
        "Return JSON only with keys: "
        "{\"vendor\": string|null, \"memo\": string|null, "
        "\"amount\": number|null, \"currency\": \"GEL\"|\"USD\"|\"EUR\"|null, "
        "\"category\": string|null, \"account_code\": string|null, "
        "\"confidence\": number|null, "
        "\"vat\": {\"rate\": number|null, \"amount\": number|null}}. "
        "No extra text."
    )

    try:
        from openai import OpenAI  # type: ignore
        client = OpenAI(api_key=key)

        # Responses API first
        try:
            r = client.responses.create(
                model=model,
                input=[
                    {"role": "system", "content": sys_prompt},
                    {"role": "user", "content": text},
                ],
                max_output_tokens=250,
            )
            raw = (getattr(r, "output_text", "") or "").strip()
            data = _ei_json_from_text(raw)
            if isinstance(data, dict) and data:
                data["source"] = "llm"
                return data
        except Exception as e:
            try:
                _log("bridge.classify.llm_responses_error", trace_id, {"err": str(e)[:200]})
            except Exception:
                pass

        # Chat Completions fallback
        try:
            r = client.chat.completions.create(
                model=model,
                messages=[
                    {"role": "system", "content": sys_prompt},
                    {"role": "user", "content": text},
                ],
            )
            content = r.choices[0].message.content if r and r.choices else ""
            data = _ei_json_from_text(content or "")
            if isinstance(data, dict) and data:
                data["source"] = "llm"
                return data
        except Exception as e:
            try:
                _log("bridge.classify.llm_chat_error", trace_id, {"err": str(e)[:200]})
            except Exception:
                pass

    except Exception as e:
        try:
            _log("bridge.classify.llm_import_error", trace_id, {"err": str(e)[:200]})
        except Exception:
            pass

    return {}


